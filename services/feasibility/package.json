{
  "name": "patentforge-feasibility",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/prompts',{recursive:true});fs.readdirSync('src/prompts').filter(f=>f.endsWith('.md')).forEach(f=>fs.copyFileSync('src/prompts/'+f,'dist/prompts/'+f))\"",
    "start": "node dist/server.js",
    "start:dev": "ts-node src/server.ts",
    "test": "jest --verbose"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "isomorphic-dompurify": "^3.7.1",
    "jsonrepair": "^3.13.3",
    "marked": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.4",
    "jest": "^29.0.0",
    "postject": "^1.0.0-alpha.6",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
