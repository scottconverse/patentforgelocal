#!/usr/bin/env bash
#
# PatentForge pre-push hook
# Runs verify-release.sh before every push. Blocks push on failure.
#
# Install: bash scripts/install-hooks.sh
# Bypass:  SKIP_VERIFY=1 git push  (emergencies only)
#

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# Emergency bypass — must be deliberate
if [ "${SKIP_VERIFY:-0}" = "1" ]; then
    echo -e "${YELLOW}========================================${NC}"
    echo -e "${YELLOW}  WARNING: Pre-push verification SKIPPED${NC}"
    echo -e "${YELLOW}  SKIP_VERIFY=1 was set${NC}"
    echo -e "${YELLOW}========================================${NC}"
    echo ""
    echo -e "${RED}  You are pushing WITHOUT running verify-release.sh.${NC}"
    echo -e "${RED}  The patentforge-release-checklist skill was also NOT run.${NC}"
    echo -e "${RED}  If this causes a problem, it's on you.${NC}"
    echo ""
    exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
VERIFY_SCRIPT="$ROOT/scripts/verify-release.sh"

if [ ! -f "$VERIFY_SCRIPT" ]; then
    echo -e "${RED}PUSH BLOCKED: scripts/verify-release.sh not found${NC}"
    exit 1
fi

echo "========================================"
echo "  Pre-push gate: running verify-release.sh"
echo "========================================"
echo ""

if bash "$VERIFY_SCRIPT"; then
    echo ""
    echo -e "${GREEN}========================================"
    echo -e "  verify-release.sh PASSED"
    echo -e "========================================${NC}"
    echo ""
    echo -e "${YELLOW}REMINDER: Also run the patentforge-release-checklist"
    echo -e "skill in Claude Code before pushing. The git hook"
    echo -e "enforces the technical gate — the skill covers"
    echo -e "browser QA, copy review, and documentation audit.${NC}"
    echo ""
    exit 0
else
    echo ""
    echo -e "${RED}========================================"
    echo -e "  PUSH BLOCKED — verify-release.sh FAILED"
    echo -e "========================================${NC}"
    echo ""
    echo -e "${RED}Fix all failures above, then try again.${NC}"
    echo -e "To bypass in an emergency: SKIP_VERIFY=1 git push"
    echo ""
    exit 1
fi
